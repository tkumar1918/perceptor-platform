# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.

# ============================================================================
# Object storage (S3-compatible)
# ============================================================================
# The stack speaks plain S3 to whatever S3_ENDPOINT points at — it does NOT
# auto-detect the provider. Pick ONE profile below and set the WHOLE block
# together: the three "addressing" flags are coupled to the endpoint, and a
# mismatch produces NoSuchBucket / TLS / DNS errors that are painful to debug.
#
# Buckets are auto-created ONLY by the bundled SeaweedFS. For AWS / R2 / B2 the
# buckets must ALREADY EXIST and the key should be least-privilege — GetObject,
# PutObject, DeleteObject, ListBucket (+ multipart) on those buckets only, and
# NOT CreateBucket / ListAllMyBuckets. (See docker-compose.yml: the `seaweedfs`
# and `s3-init` services must be disabled for any external S3 — they auto-create
# buckets and list-all, which hangs under a scoped policy.)

# ---------------------------------------------------------------------------
# PROFILE A — bundled SeaweedFS (local dev, zero external setup)   [DEFAULT]
# ---------------------------------------------------------------------------
S3_ENDPOINT=seaweedfs:8333              # host:port (no scheme) for the backends
S3_ENDPOINT_URL=http://seaweedfs:8333   # full URL for tooling
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=perceptor
S3_SECRET_ACCESS_KEY=CHANGE-ME-long-random-string
# -- addressing: flip these THREE together with the endpoint --
S3_INSECURE=true                        # http, no TLS (internal network)
S3_FORCE_PATH_STYLE=true                # host/BUCKET/obj — self-hosted needs this
S3_BUCKET_LOOKUP=path                   # Mimir's name for the same knob (path|virtual-hosted|auto)

# ---------------------------------------------------------------------------
# PROFILE B — AWS S3 (or R2 / B2)
#   To use: comment out Profile A above, uncomment this block, AND in
#   docker-compose.yml disable the `seaweedfs` + `s3-init` services and drop the
#   `s3-init` dependency from mimir/loki/tempo (buckets must pre-exist).
# ---------------------------------------------------------------------------
# S3_ENDPOINT=s3.ap-south-1.amazonaws.com
# S3_ENDPOINT_URL=https://s3.ap-south-1.amazonaws.com
# S3_REGION=ap-south-1
# S3_ACCESS_KEY_ID=<aws access key, least-privilege>
# S3_SECRET_ACCESS_KEY=<aws secret key>
# -- addressing (AWS = virtual-hosted) --
# S3_INSECURE=false                     # https
# S3_FORCE_PATH_STYLE=false             # BUCKET.s3.region.amazonaws.com
# S3_BUCKET_LOOKUP=auto
#
# Cloudflare R2 / Backblaze B2: same shape as AWS, BUT keep path-style —
#   S3_FORCE_PATH_STYLE=true  and  S3_BUCKET_LOOKUP=path

# ---------------------------------------------------------------------------
# PROFILE C — AWS S3 with an EC2 INSTANCE ROLE (preferred on EC2: no static keys)
#   Same as Profile B, but leave BOTH credential values EMPTY. Empty creds fall
#   through to the AWS SDK default chain, which resolves the instance role via
#   IMDS — so no long-lived secret ever sits in this file. Do NOT "fix" the
#   empty values by pasting keys in; the role is the better auth.
#   Requires: an instance profile granting the bucket policy described above,
#   and (for the containers to reach IMDS) a metadata hop limit >= 2.
# ---------------------------------------------------------------------------
# S3_ENDPOINT=s3.us-east-2.amazonaws.com
# S3_ENDPOINT_URL=https://s3.us-east-2.amazonaws.com
# S3_REGION=us-east-2
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_INSECURE=false
# S3_FORCE_PATH_STYLE=false
# S3_BUCKET_LOOKUP=auto

# --- Buckets: names you PROVIDE (must pre-exist for Profile B) ---
BUCKET_MIMIR=mimir-blocks               # e.g. perceptor-prod-metrics
BUCKET_LOKI=loki-data                   # e.g. perceptor-prod-logs
BUCKET_TEMPO=tempo-data                 # e.g. perceptor-prod-traces

# ============================================================================
# Grafana admin
# ============================================================================
GRAFANA_ADMIN_PASSWORD=CHANGE-ME-strong-password

# ============================================================================
# Alert email delivery (OPTIONAL) — SMTP for Grafana notifications
# ============================================================================
# Off by default. Needed only if a contact point uses type: email (see
# provisioning/alerting/contact-points.yaml.example). For Gmail: enable 2FA,
# create an App Password at https://myaccount.google.com/apppasswords — the
# account password itself will NOT work.
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.gmail.com:587
# GF_SMTP_USER=you@gmail.com
# GF_SMTP_PASSWORD=xxxx xxxx xxxx xxxx     # the 16-char app password
# GF_SMTP_FROM_ADDRESS=you@gmail.com

# Project ingest tokens live in tenants.yaml (per project), not here.

# ============================================================================
# Public TLS edge (OPTIONAL) — let Caddy terminate HTTPS itself
# ============================================================================
# Leave this whole block UNSET for local dev, or when you keep the edge behind
# an existing TLS front (nginx/ELB): Caddy then stays a plain :4318 HTTP edge,
# exactly as before, and 80/443 are bound to localhost only (no clash).
#
# Set it to have Caddy own the public edge with auto-provisioned + auto-renewed
# Let's Encrypt certs — no nginx, no certbot. Requires: the hostname(s) resolve
# to this box, and 80+443 reachable from the internet.
#
# EDGE_HOST=lgtm.example.com            # ingest hostname (Caddy gets its cert)
# GRAFANA_HOST=monitoring.example.com   # optional: also front Grafana on 443
# ACME_EMAIL=ops@example.com            # Let's Encrypt account (expiry notices)
#
# Which interfaces the host exposes (defaults keep local dev simple + safe):
#   EDGE_BIND     public edge 80+443. Default 127.0.0.1 (nothing public, no nginx
#                 clash). On the TLS box set 0.0.0.0 to face the internet.
#   SERVICE_BIND  the plain OTLP :4318 + Grafana :3001 UI. Default 0.0.0.0 (easy
#                 local access). On the TLS box set 127.0.0.1 so everything rides
#                 443 and 80+443 are the ONLY public ports (:4318/:3001 stay on-box).
# EDGE_BIND=0.0.0.0
# SERVICE_BIND=127.0.0.1
