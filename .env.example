# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.

# ============================================================================
# Object storage (S3-compatible).
# The stack is S3-generic: these vars are the ONLY thing that changes when you
# move from the bundled SeaweedFS to AWS S3 / Cloudflare R2 / Backblaze B2.
# ============================================================================

# --- Default: bundled SeaweedFS (self-hosted, Apache-2.0, on the obs network) ---
S3_ENDPOINT=seaweedfs:8333              # host:port (no scheme) for the backends
S3_ENDPOINT_URL=http://seaweedfs:8333   # full URL for the bucket-init / tooling
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=perceptor
S3_SECRET_ACCESS_KEY=CHANGE-ME-long-random-string
S3_INSECURE=true                        # http (no TLS) on the internal network
S3_FORCE_PATH_STYLE=true                # path-style addressing (self-hosted S3)
S3_BUCKET_LOOKUP=path                   # Mimir's equivalent knob (path|auto)

BUCKET_MIMIR=mimir-blocks
BUCKET_LOKI=loki-data
BUCKET_TEMPO=tempo-data

# --- To switch to AWS S3 later: stop the seaweedfs/s3-init services and set ---
#   S3_ENDPOINT=s3.us-east-1.amazonaws.com
#   S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
#   S3_REGION=us-east-1
#   S3_ACCESS_KEY_ID=<aws access key>
#   S3_SECRET_ACCESS_KEY=<aws secret key>
#   S3_INSECURE=false
#   S3_FORCE_PATH_STYLE=false
#   S3_BUCKET_LOOKUP=auto
# (Cloudflare R2 / Backblaze B2: same shape, just their endpoint + keys, and
#  keep S3_FORCE_PATH_STYLE=true for R2.)

# ============================================================================
# Grafana admin
# ============================================================================
GRAFANA_ADMIN_PASSWORD=CHANGE-ME-strong-password

# Project ingest tokens live in tenants.yaml (per project), not here.
