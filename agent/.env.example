# ============================================================================
# Perceptor VM agent — copy to .env and fill in for THIS vm.
# ============================================================================

# Platform ingest edge (OTLP/HTTP). Same URL your apps push telemetry to.
EDGE_ENDPOINT=https://lgtm.runtheday.com

# This PROJECT's ingest token — from tenants.secrets.yaml on the central server.
# Caddy maps it to the tenant; the VM never names its own tenant.
PROJECT_TOKEN=ptk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A name for THIS machine (becomes the `vm` label on its metrics/logs).
VM_NAME=project-alpha-vm-1
