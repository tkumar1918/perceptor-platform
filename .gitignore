# secrets
.env
.env.*
*.env
!.env.example
tenants.secrets.yaml
# alert delivery config — holds a webhook URL (treat as a secret); the
# committed template is contact-points.yaml.example
docker/grafana/provisioning/alerting/contact-points.yaml

# per-instance config — YOUR real project list. Each deployment has its own
# projects, so this is never shared; tenants.example.yaml is the committed template.
tenants.yaml

# python
.venv/
__pycache__/
*.pyc

# renderer scratch
scripts/.orgs

# generated by `make render` — embeds the rendered ingest tokens (regenerate on clone)
docker/caddy/Caddyfile

# generated by `make render` — one dead-man alert per group in THIS instance's
# tenants.yaml (per-instance content; committing it would guarantee pull
# conflicts on every deployment, like any other render output)
docker/grafana/provisioning/alerting/group-agent-alerts.yaml

# generated by `make render` — per-instance Grafana org_id allocations. Each
# deployment has its own Grafana (orgs resolved by name at bootstrap), so this is
# local state, NOT shared. Regenerated on clone; never commit it.
tenants.lock.yaml

# os
.DS_Store

# of no use
temp/
