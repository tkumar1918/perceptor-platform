{
  "uid": "perceptor-infra",
  "id": null,
  "title": "Infrastructure — hosts & containers",
  "tags": ["perceptor", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "description": "Portable infra dashboard. Works in ANY org: pick the Mimir/Loki datasource for the tenant you're viewing. Driven by the agent's node-exporter + cadvisor metrics (labelled telemetry_source=infra, vm, container).",
  "templating": {
    "list": [
      {
        "name": "mimir",
        "label": "Metrics source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "loki",
        "label": "Logs source",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "vm",
        "label": "VM",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${mimir}" },
        "query": "label_values(node_uname_info, vm)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Fleet overview", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false, "id": 100 },

    {
      "type": "stat", "title": "Hosts reporting", "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "count(group by (vm) (node_uname_info{vm=~\"$vm\"}))", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "none" }
    },
    {
      "type": "stat", "title": "Max CPU busy", "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "max(100 * (1 - avg by (vm) (rate(node_cpu_seconds_total{mode=\"idle\", vm=~\"$vm\"}[5m]))))", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "type": "stat", "title": "Max memory used", "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "max(100 * (1 - node_memory_MemAvailable_bytes{vm=~\"$vm\"} / node_memory_MemTotal_bytes{vm=~\"$vm\"}))", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 92 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "type": "stat", "title": "Fullest filesystem", "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "max(100 * (1 - node_filesystem_avail_bytes{vm=~\"$vm\", mountpoint!=\"\"} / node_filesystem_size_bytes{vm=~\"$vm\", mountpoint!=\"\"}))", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },

    { "type": "row", "title": "Host — CPU, memory, disk", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "collapsed": false, "id": 101 },

    {
      "type": "timeseries", "title": "CPU busy % (per VM)", "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "100 * (1 - avg by (vm) (rate(node_cpu_seconds_total{mode=\"idle\", vm=~\"$vm\"}[5m])))", "legendFormat": "{{vm}}" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Memory used % (per VM)", "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "100 * (1 - node_memory_MemAvailable_bytes{vm=~\"$vm\"} / node_memory_MemTotal_bytes{vm=~\"$vm\"})", "legendFormat": "{{vm}}" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Filesystem used % (per mount)", "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "100 * (1 - node_filesystem_avail_bytes{vm=~\"$vm\", mountpoint!=\"\"} / node_filesystem_size_bytes{vm=~\"$vm\", mountpoint!=\"\"})", "legendFormat": "{{vm}} {{mountpoint}}" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Load average (1m per VM)", "id": 13,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "node_load1{vm=~\"$vm\"}", "legendFormat": "{{vm}}" } ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "title": "Host — disk & network I/O", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }, "collapsed": false, "id": 102 },

    {
      "type": "timeseries", "title": "Disk I/O (bytes/s)", "id": 20,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [
        { "refId": "A", "expr": "sum by (vm) (rate(node_disk_read_bytes_total{vm=~\"$vm\"}[5m]))", "legendFormat": "{{vm}} read" },
        { "refId": "B", "expr": "-sum by (vm) (rate(node_disk_written_bytes_total{vm=~\"$vm\"}[5m]))", "legendFormat": "{{vm}} write" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Network (bytes/s, lo excluded)", "id": 21,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [
        { "refId": "A", "expr": "sum by (vm) (rate(node_network_receive_bytes_total{vm=~\"$vm\", device!~\"lo\"}[5m]))", "legendFormat": "{{vm}} rx" },
        { "refId": "B", "expr": "-sum by (vm) (rate(node_network_transmit_bytes_total{vm=~\"$vm\", device!~\"lo\"}[5m]))", "legendFormat": "{{vm}} tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "title": "Containers (cadvisor)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }, "collapsed": false, "id": 103 },

    {
      "type": "timeseries", "title": "Container CPU (cores)", "id": 30,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "sum by (container) (rate(container_cpu_usage_seconds_total{vm=~\"$vm\", container!=\"\"}[5m]))", "legendFormat": "{{container}}" } ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries", "title": "Container memory (working set)", "id": 31,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "sum by (container) (container_memory_working_set_bytes{vm=~\"$vm\", container!=\"\"})", "legendFormat": "{{container}}" } ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "table", "title": "Running containers (last seen ≤ 2m)", "id": 32,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "${mimir}" },
      "targets": [ { "refId": "A", "expr": "count by (vm, container) (time() - container_last_seen{vm=~\"$vm\", container!=\"\"} < 120)", "instant": true, "format": "table" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true }, "renameByName": { "vm": "VM", "container": "Container" } } } ],
      "options": { "showHeader": true }
    },

    { "type": "row", "title": "Infra logs", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 }, "collapsed": false, "id": 104 },

    {
      "type": "logs", "title": "Host + container logs (telemetry_source=infra)", "id": 40,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 50 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [ { "refId": "A", "expr": "{telemetry_source=\"infra\", vm=~\"$vm\"}" } ],
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" }
    }
  ]
}
